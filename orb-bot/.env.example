# ORB Bot environment variables
# ------------------------------
# LOCAL DEV: copy this file to `.env` and fill in real values (.env is gitignored).
# RAILWAY:  do NOT use a .env file — add each of these in the Railway dashboard
#           under your service → Variables. They are injected into process.env.

# --- Alpaca (PAPER trading only in this phase) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Account / risk ---
ACCOUNT_SIZE=100000
MAX_RISK_PER_TRADE=0.01
TIMEZONE=America/New_York

# --- Perplexity (gap catalyst classification) ---
PERPLEXITY_API_KEY=

# --- Discord (breakout signal notifications) ---
# Discord: Channel → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# --- Optional ---
# ALPACA_DATA_FEED=iex      # 'iex' (free) or 'sip' (paid consolidated feed)
# LOG_TO_FILE=false         # true = also write logs/ files (ephemeral on Railway)
# LOG_LEVEL=info            # debug | info | warn | error
